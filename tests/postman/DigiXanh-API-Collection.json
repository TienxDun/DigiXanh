    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get Admin Plants",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/plants",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "plants"]
            }
          },
          "response": []
        },
        {
          "name": "Create Plant",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cây Test\",\n  \"scientificName\": \"Test Plant\",\n  \"description\": \"Test description\",\n  \"price\": 150000,\n  \"categoryId\": 1,\n  \"stockQuantity\": 100\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/plants",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "plants"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],
  "variable": [
