              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipientName\": \"Nguyễn Văn A\",\n  \"phone\": \"0900000000\",\n  \"shippingAddress\": \"123 Lê Lợi, Quận 1, TP.HCM\",\n  \"paymentMethod\": 0\n}"
            },
            "url": {
