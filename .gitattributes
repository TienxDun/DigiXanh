# =============================================
# DigiXanh - Git Attributes
# =============================================

# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.cs text diff=csharp
*.ts text
*.js text
*.html text diff=html
*.css text
*.scss text
*.json text
*.xml text

# Scripts
*.ps1 text eol=crlf
*.sh text eol=lf
*.cmd text eol=crlf
*.bat text eol=crlf

# Config files
*.config text
*.conf text
*.ini text
*.yml text
*.yaml text
*.toml text

# Documentation
*.md text diff=markdown
*.txt text
*.rtf text

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
*.webp binary

# Audio/Video
*.mp3 binary
*.mp4 binary
*.wav binary
*.avi binary
*.mov binary

# Archives
*.zip binary
*.gz binary
*.7z binary
*.rar binary
*.tar binary

# Documents
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary

# Fonts
*.ttf binary
*.eot binary
*.woff binary
*.woff2 binary

# Executables
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Database
*.db binary
*.sqlite binary
*.mdb binary

# =============================================
# Merge Settings
# =============================================
# Use union merge for project files
*.sln merge=union
*.csproj merge=union
*.vbproj merge=union

# Use custom merge driver for specific files
package-lock.json merge=npm-merge-driver
yarn.lock merge=yarn-merge-driver
